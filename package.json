{
  "name": "hotornottakes",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "typecheck:functions": "npm --prefix functions run typecheck",
    "build:functions": "npm --prefix functions run build",
    "audit:corpus": "tsx src/scripts/auditCorpus.ts",
    "hygiene:corpus": "tsx src/scripts/applyCorpusHygiene.ts",
    "cleanup:ai-duplicates": "tsx src/scripts/cleanupAIDuplicates.ts",
    "generate": "node scripts/generateTakes-simple.js",
    "generate:all": "node scripts/generateTakes-simple.js all 10"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/stack": "^7.4.5",
    "@types/lodash": "^4.17.20",
    "expo": "~53.0.27",
    "expo-build-properties": "~0.14.8",
    "expo-dev-client": "~5.2.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-notifications": "~0.31.5",
    "expo-status-bar": "~2.2.3",
    "expo-store-review": "~8.1.5",
    "expo-updates": "~0.28.18",
    "firebase": "^12.0.0",
    "lodash": "^4.17.21",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-deck-swiper": "^2.0.18",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-google-mobile-ads": "^15.4.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-share": "^12.2.0",
    "react-native-view-shot": "^4.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.0.10",
    "firebase-admin": "^13.10.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3"
  },
